<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Conversación | Margarita</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="min-h-screen bg-slate-100">
    <header class="border-b bg-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            <div>
                <h1 class="text-xl font-bold text-emerald-600">Margarita</h1>
                <p class="text-sm text-slate-500">Detalle de conversación</p>
            </div>

            <nav class="flex items-center gap-3">
                <a href="/admin/conversations" class="text-sm font-medium text-slate-700">
                    ← Conversaciones
                </a>

                <form action="/auth/logout" method="POST">
                    <button class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white">
                        Cerrar sesión
                    </button>
                </form>
            </nav>
        </div>
    </header>

    <main class="mx-auto grid max-w-6xl gap-6 px-6 py-8 lg:grid-cols-[1fr_340px]">
        <section class="rounded-2xl bg-white shadow">
            <div class="border-b px-6 py-4">
                <h2 class="text-xl font-bold text-slate-800">
                    <%= conversation.contact.customName || conversation.contact.profileName || conversation.contact.phone %>
                </h2>

                <p class="mt-1 text-sm text-slate-500">
                    <%= conversation.contact.phone %>
                </p>
            </div>

            <% if (success === "assigned") { %>
                <div class="mx-6 mt-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                    Conversación asignada correctamente.
                </div>
            <% } %>

            <% if (success === "closed") { %>
                <div class="mx-6 mt-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                    Conversación cerrada correctamente.
                </div>
            <% } %>

            <% if (success === "reopened") { %>
                <div class="mx-6 mt-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                    Conversación reabierta correctamente.
                </div>
            <% } %>

            <% if (error && error !== "message" && error !== "template" && error !== "free_text") { %>
                <div class="mx-6 mt-4 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                    No se pudo completar la acción.
                </div>
            <% } %>

            <div class="min-h-[420px] space-y-4 bg-slate-50 p-6">
                <% if (conversation.messages.length === 0) { %>
                    <div class="rounded-xl bg-white p-5 text-center text-sm text-slate-500">
                        Todavía no hay mensajes en esta conversación.
                    </div>
                <% } %>

                <% conversation.messages.forEach((message) => { %>
                    <% const isOut = message.direction === "OUT"; %>

                    <div class="flex <%= isOut ? 'justify-end' : 'justify-start' %>">
                        <div class="max-w-[75%] rounded-2xl px-4 py-3 shadow-sm <%= isOut ? 'bg-emerald-600 text-white' : 'bg-white text-slate-800' %>">
                            <p class="whitespace-pre-line text-sm">
                                <%= message.body || '[' + message.type + ']' %>
                            </p>

                            <p class="mt-2 text-right text-[11px] <%= isOut ? 'text-emerald-100' : 'text-slate-400' %>">
                                <%= message.createdAt.toLocaleString("es-MX") %>
                                · <%= message.status %>

                                <% if (message.source === "MANUAL") { %>
                                    · Manual
                                <% } %>
                            </p>
                        </div>
                    </div>
                <% }) %>
            </div>

            <%
                const hasOpenWindow =
                    conversation.lastIncomingMessageAt &&
                    new Date().getTime() - new Date(conversation.lastIncomingMessageAt).getTime() <= 24 * 60 * 60 * 1000;
            %>

            <div class="border-t p-4">
                <% if (success === "message") { %>
                    <div class="mb-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                        Mensaje local guardado correctamente.
                    </div>
                <% } %>

                <% if (success === "template") { %>
                    <div class="mb-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                        Plantilla enviada correctamente a Meta.
                    </div>
                <% } %>

                <% if (success === "free_text") { %>
                    <div class="mb-4 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                        Mensaje de texto enviado correctamente.
                    </div>
                <% } %>

                <% if (error === "message") { %>
                    <div class="mb-4 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                        No se pudo guardar el mensaje.
                    </div>
                <% } %>

                <% if (error === "template") { %>
                    <div class="mb-4 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                        No se pudo enviar la plantilla. Revisa que esté aprobada, que las variables estén completas y que Meta esté configurado.
                    </div>
                <% } %>

                <% if (error === "free_text") { %>
                    <div class="mb-4 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                        No se pudo enviar el texto libre. Verifica que la ventana de 24 horas siga abierta.
                    </div>
                <% } %>

                <% if (conversation.status === "OPEN") { %>
                    <div class="grid gap-4 lg:grid-cols-3">
                        <form action="/admin/conversations/<%= conversation.id %>/messages/local" method="POST" class="space-y-3 rounded-2xl border border-slate-200 p-4">
                            <h3 class="font-bold text-slate-800">
                                Mensaje local
                            </h3>

                            <textarea
                                name="body"
                                rows="3"
                                placeholder="Escribe un mensaje local de prueba..."
                                class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                            ></textarea>

                            <p class="text-xs text-slate-500">
                                Solo se guarda en Margarita. No se envía a Meta.
                            </p>

                            <button class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800">
                                Guardar local
                            </button>
                        </form>

                        <form action="/admin/conversations/<%= conversation.id %>/messages/free-text" method="POST" class="space-y-3 rounded-2xl border border-blue-200 bg-blue-50 p-4">
                            <h3 class="font-bold text-slate-800">
                                Respuesta libre 24h
                            </h3>

                            <% if (hasOpenWindow) { %>
                                <textarea
                                    name="body"
                                    rows="3"
                                    placeholder="Escribe una respuesta real por WhatsApp..."
                                    class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-blue-500 focus:ring-2 focus:ring-blue-100"
                                ></textarea>

                                <p class="text-xs text-blue-800">
                                    Se enviará como texto real porque el cliente escribió dentro de las últimas 24 horas.
                                </p>

                                <button class="rounded-xl bg-blue-600 px-5 py-3 text-sm font-semibold text-white hover:bg-blue-700">
                                    Enviar texto
                                </button>
                            <% } else { %>
                                <div class="rounded-xl bg-white px-4 py-3 text-sm text-slate-500">
                                    La ventana de 24 horas está cerrada. Usa una plantilla aprobada.
                                </div>
                            <% } %>
                        </form>

                        <form action="/admin/conversations/<%= conversation.id %>/messages/template" method="POST" class="space-y-3 rounded-2xl border border-emerald-200 bg-emerald-50 p-4">
                            <h3 class="font-bold text-slate-800">
                                Enviar plantilla Meta
                            </h3>

                            <% if (templates.length === 0) { %>
                                <div class="rounded-xl bg-white px-4 py-3 text-sm text-slate-500">
                                    No hay plantillas aprobadas sincronizadas.
                                </div>
                            <% } else { %>
                                <select
                                    name="templateId"
                                    required
                                    class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                                >
                                    <option value="">Selecciona plantilla</option>

                                    <% templates.forEach((template) => { %>
                                        <option value="<%= template.id %>">
                                            <%= template.name %> · <%= template.language %>
                                        </option>
                                    <% }) %>
                                </select>

                                <div class="grid gap-2 md:grid-cols-3">
                                    <input
                                        name="variable1"
                                        placeholder="Variable 1"
                                        class="rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                                    />

                                    <input
                                        name="variable2"
                                        placeholder="Variable 2"
                                        class="rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                                    />

                                    <input
                                        name="variable3"
                                        placeholder="Variable 3"
                                        class="rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                                    />
                                </div>

                                <p class="text-xs text-emerald-800">
                                    Se enviará realmente a WhatsApp usando Meta Cloud API.
                                </p>

                                <button class="rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700">
                                    Enviar plantilla
                                </button>
                            <% } %>
                        </form>
                    </div>
                <% } else { %>
                    <div class="rounded-xl bg-slate-50 px-4 py-3 text-sm text-slate-500">
                        Esta conversación está cerrada. Reábrela para escribir mensajes.
                    </div>
                <% } %>
            </div>
        </section>

        <aside class="space-y-5">
            <section class="rounded-2xl bg-white p-5 shadow">
                <h3 class="font-bold text-slate-800">
                    Asignación
                </h3>

                <form action="/admin/conversations/<%= conversation.id %>/assign" method="POST" class="mt-4 space-y-3">
                    <select
                        name="agentId"
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                    >
                        <option value="">Sin asignar</option>

                        <% agents.forEach((agent) => { %>
                            <option
                                value="<%= agent.id %>"
                                <% if (conversation.assignedUserId === agent.id) { %> selected <% } %>
                            >
                                <%= agent.name %> · <%= agent.status %>
                            </option>
                        <% }) %>
                    </select>

                    <button class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white hover:bg-emerald-700">
                        Guardar asignación
                    </button>
                </form>

                <p class="mt-3 text-xs text-slate-500">
                    Si seleccionas “Sin asignar”, la conversación vuelve a la bandeja del Admin.
                </p>
            </section>

            <section class="rounded-2xl bg-white p-5 shadow">
                <h3 class="font-bold text-slate-800">
                    Datos
                </h3>

                <dl class="mt-4 space-y-3 text-sm">
                    <div>
                        <dt class="text-slate-500">Estado</dt>
                        <dd class="font-medium text-slate-800"><%= conversation.status %></dd>
                    </div>

                    <div>
                        <dt class="text-slate-500">Operación</dt>
                        <dd class="font-medium text-slate-800"><%= conversation.operationalStatus %></dd>
                    </div>

                    <div>
                        <dt class="text-slate-500">Origen</dt>
                        <dd class="font-medium text-slate-800"><%= conversation.source %></dd>
                    </div>

                    <div>
                        <dt class="text-slate-500">Asignado a</dt>
                        <dd class="font-medium text-slate-800">
                            <% if (conversation.assignedUser) { %>
                                <%= conversation.assignedUser.name %>
                            <% } else { %>
                                Sin asignar
                            <% } %>
                        </dd>
                    </div>

                    <div>
                        <dt class="text-slate-500">Último mensaje entrante</dt>
                        <dd class="font-medium text-slate-800">
                            <% if (conversation.lastIncomingMessageAt) { %>
                                <%= conversation.lastIncomingMessageAt.toLocaleString("es-MX") %>
                            <% } else { %>
                                —
                            <% } %>
                        </dd>
                    </div>

                    <div>
                        <dt class="text-slate-500">Ventana 24h</dt>
                        <dd class="font-medium <%= hasOpenWindow ? 'text-emerald-700' : 'text-red-700' %>">
                            <% if (hasOpenWindow) { %>
                                Abierta
                            <% } else { %>
                                Cerrada
                            <% } %>
                        </dd>
                    </div>
                </dl>
            </section>

            <section class="rounded-2xl bg-white p-5 shadow">
                <h3 class="font-bold text-slate-800">
                    Etiquetas
                </h3>

                <div class="mt-4 flex flex-wrap gap-2">
                    <% if (conversation.contact.tags.length === 0) { %>
                        <span class="text-sm text-slate-400">Sin etiquetas</span>
                    <% } %>

                    <% conversation.contact.tags.forEach((contactTag) => { %>
                        <span
                            class="rounded-full px-3 py-1 text-xs font-semibold text-white"
                            style="background-color: <%= contactTag.tag.color || '#10b981' %>;"
                        >
                            <%= contactTag.tag.name %>
                        </span>
                    <% }) %>
                </div>
            </section>

            <section class="rounded-2xl bg-white p-5 shadow">
                <h3 class="font-bold text-slate-800">
                    Acciones
                </h3>

                <div class="mt-4 space-y-3">
                    <% if (conversation.status === "OPEN") { %>
                        <form action="/admin/conversations/<%= conversation.id %>/close" method="POST">
                            <button class="w-full rounded-xl bg-slate-900 px-4 py-3 text-sm font-semibold text-white">
                                Cerrar conversación
                            </button>
                        </form>
                    <% } else { %>
                        <form action="/admin/conversations/<%= conversation.id %>/reopen" method="POST">
                            <button class="w-full rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white">
                                Reabrir conversación
                            </button>
                        </form>
                    <% } %>
                </div>
            </section>

            <section class="rounded-2xl bg-white p-5 shadow">
                <h3 class="font-bold text-slate-800">
                    Historial de asignación
                </h3>

                <div class="mt-4 space-y-3 text-sm text-slate-600">
                    <% if (conversation.assignments.length === 0) { %>
                        <p class="text-slate-400">
                            Sin asignaciones registradas.
                        </p>
                    <% } %>

                    <% conversation.assignments.forEach((assignment) => { %>
                        <div class="rounded-xl bg-slate-50 p-3">
                            <p>
                                <strong><%= assignment.assignedBy.name %></strong>
                                asignó de
                                <strong><%= assignment.fromUser ? assignment.fromUser.name : 'Sin asignar' %></strong>
                                a
                                <strong><%= assignment.toUser ? assignment.toUser.name : 'Sin asignar' %></strong>
                            </p>

                            <p class="mt-1 text-xs text-slate-400">
                                <%= assignment.createdAt.toLocaleString("es-MX") %>
                            </p>
                        </div>
                    <% }) %>
                </div>
            </section>
        </aside>
    </main>
</body>
</html>
