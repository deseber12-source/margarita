<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Agentes | Margarita</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="min-h-screen bg-slate-100">
    <header class="border-b bg-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            <div>
                <h1 class="text-xl font-bold text-emerald-600">Margarita</h1>
                <p class="text-sm text-slate-500">Agentes</p>
            </div>

            <nav class="flex items-center gap-3">
                <a href="/admin/dashboard" class="text-sm font-medium text-slate-700">
                    Dashboard
                </a>

                <a href="/admin/users" class="text-sm font-medium text-emerald-700">
                    Agentes
                </a>
                <a href="/admin/contacts" class="text-sm font-medium text-slate-700">
                    Contactos
                </a>
                <a href="/admin/tags" class="text-sm font-medium text-slate-700">
                    Etiquetas
                </a>
                <a href="/admin/whatsapp" class="text-sm font-medium text-slate-700">
                    WhatsApp
                </a>

                <a href="/admin/templates" class="text-sm font-medium text-slate-700">
                    Plantillas
                </a>

                <a href="/admin/conversations" class="text-sm font-medium text-slate-700">
                    Conversaciones
                </a>

                <form action="/auth/logout" method="POST">
                    <button class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white">
                        Cerrar sesión
                    </button>
                </form>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-8">
        <section class="mb-6 flex items-center justify-between">
            <div>
                <h2 class="text-2xl font-bold text-slate-800">Agentes</h2>
                <p class="mt-1 text-slate-500">
                    Administra los usuarios que atenderán conversaciones.
                </p>
            </div>

            <a
                href="/admin/users/new"
                class="rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white hover:bg-emerald-700"
            >
                Nuevo agente
            </a>
        </section>

        <% if (success) { %>
            <div class="mb-5 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                Acción realizada correctamente.
            </div>
        <% } %>

        <section class="overflow-hidden rounded-2xl bg-white shadow">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th class="px-5 py-4">Nombre</th>
                        <th class="px-5 py-4">Correo</th>
                        <th class="px-5 py-4">Estado</th>
                        <th class="px-5 py-4">Activo</th>
                        <th class="px-5 py-4">Manual</th>
                        <th class="px-5 py-4 text-right">Acciones</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    <% if (agents.length === 0) { %>
                        <tr>
                            <td colspan="6" class="px-5 py-8 text-center text-slate-500">
                                Todavía no hay agentes creados.
                            </td>
                        </tr>
                    <% } %>

                    <% agents.forEach((agent) => { %>
                        <tr>
                            <td class="px-5 py-4 font-medium text-slate-800">
                                <%= agent.name %>
                            </td>

                            <td class="px-5 py-4 text-slate-600">
                                <%= agent.email %>
                            </td>

                            <td class="px-5 py-4">
                                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-medium text-slate-700">
    <% if (agent.status === "AVAILABLE") { %>
        Disponible
    <% } else if (agent.status === "BUSY") { %>
        Ocupado
    <% } else if (agent.status === "BREAK") { %>
        Pausa
    <% } else { %>
        Desconectado
    <% } %>
                                </span>

                            <td class="px-5 py-4">
                                <% if (agent.isActive) { %>
                                    <span class="rounded-full bg-emerald-100 px-3 py-1 text-xs font-medium text-emerald-700">
                                        Activo
                                    </span>
                                <% } else { %>
                                    <span class="rounded-full bg-red-100 px-3 py-1 text-xs font-medium text-red-700">
                                        Inactivo
                                    </span>
                                <% } %>
                            </td>

                            <td class="px-5 py-4 text-slate-600">
                                <% if (agent.canSendManualMessages) { %>
                                    Sí
                                <% } else { %>
                                    No
                                <% } %>
                            </td>

                            <td class="px-5 py-4">
                                <div class="flex justify-end gap-2">
                                    <a
                                        href="/admin/users/<%= agent.id %>/edit"
                                        class="rounded-lg bg-slate-100 px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-200"
                                    >
                                        Editar
                                    </a>

                                    <form action="/admin/users/<%= agent.id %>/toggle-status" method="POST">
                                        <button
                                            class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-medium text-white"
                                        >
                                            <% if (agent.isActive) { %>
                                                Desactivar
                                            <% } else { %>
                                                Activar
                                            <% } %>
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>
