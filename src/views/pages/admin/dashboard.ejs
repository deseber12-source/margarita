<%- include("../../partials/header", { title: "Dashboard Admin" }) %>

<div class="min-h-screen bg-slate-100">
    <%- include("../../partials/admin-nav", { user }) %>

    <main class="mx-auto max-w-7xl px-4 py-8">
        <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">
                Panel operativo
            </p>

            <h1 class="mt-1 text-3xl font-bold text-slate-900">
                Dashboard
            </h1>

            <p class="mt-2 text-slate-600">
                Vista rápida del estado actual de conversaciones, agentes y eventos recientes.
            </p>
        </div>

        <section class="grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm font-medium text-slate-500">
                    Conversaciones abiertas
                </p>

                <p class="mt-3 text-4xl font-bold text-slate-900">
                    <%= dashboard.stats.openConversations %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-orange-200">
                <p class="text-sm font-medium text-orange-600">
                    Sin asignar
                </p>

                <p class="mt-3 text-4xl font-bold text-orange-700">
                    <%= dashboard.stats.unassignedConversations %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-blue-200">
                <p class="text-sm font-medium text-blue-600">
                    Asignadas
                </p>

                <p class="mt-3 text-4xl font-bold text-blue-700">
                    <%= dashboard.stats.assignedConversations %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-emerald-200">
                <p class="text-sm font-medium text-emerald-600">
                    En progreso
                </p>

                <p class="mt-3 text-4xl font-bold text-emerald-700">
                    <%= dashboard.stats.inProgressConversations %>
                </p>
            </div>
        </section>

        <section class="mt-6 grid gap-4 md:grid-cols-2 xl:grid-cols-4">
            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    Agentes disponibles
                </p>

                <p class="mt-2 text-3xl font-bold text-emerald-600">
                    <%= dashboard.agents.available %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    Ocupados
                </p>

                <p class="mt-2 text-3xl font-bold text-yellow-600">
                    <%= dashboard.agents.busy %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    En break
                </p>

                <p class="mt-2 text-3xl font-bold text-blue-600">
                    <%= dashboard.agents.break %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    Offline
                </p>

                <p class="mt-2 text-3xl font-bold text-slate-500">
                    <%= dashboard.agents.offline %>
                </p>
            </div>
        </section>

        <section class="mt-8 grid gap-6 xl:grid-cols-2">
            <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                <div class="border-b border-slate-200 px-6 py-4">
                    <h2 class="font-bold text-slate-900">
                        Conversaciones recientes
                    </h2>
                </div>

                <div class="divide-y divide-slate-100">
                    <% if (dashboard.recentConversations.length === 0) { %>
                        <div class="px-6 py-8 text-sm text-slate-500">
                            No hay conversaciones abiertas todavía.
                        </div>
                    <% } %>

                    <% dashboard.recentConversations.forEach((conversation) => { %>
                        <a href="/admin/conversations/<%= conversation.id %>" class="block px-6 py-4 hover:bg-slate-50">
                            <div class="flex items-start justify-between gap-4">
                                <div>
                                    <p class="font-semibold text-slate-900">
                                        <%= conversation.contact.name || conversation.contact.profileName || conversation.contact.phone %>
                                    </p>

                                    <p class="mt-1 line-clamp-1 text-sm text-slate-500">
                                        <% if (conversation.messages.length > 0) { %>
                                            <%= conversation.messages[0].body || "[" + conversation.messages[0].type + "]" %>
                                        <% } else { %>
                                            Sin mensajes todavía
                                        <% } %>
                                    </p>
                                </div>

                                <div class="text-right">
                                    <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                                        <%= conversation.operationalStatus %>
                                    </span>

                                    <p class="mt-2 text-xs text-slate-400">
                                        <%= conversation.assignedUser ? conversation.assignedUser.name : "Sin agente" %>
                                    </p>
                                </div>
                            </div>
                        </a>
                    <% }) %>
                </div>
            </div>

            <div class="rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
                <div class="border-b border-slate-200 px-6 py-4">
                    <h2 class="font-bold text-slate-900">
                        Mensajes entrantes recientes
                    </h2>
                </div>

                <div class="divide-y divide-slate-100">
                    <% if (dashboard.recentIncomingMessages.length === 0) { %>
                        <div class="px-6 py-8 text-sm text-slate-500">
                            No hay mensajes entrantes todavía.
                        </div>
                    <% } %>

                    <% dashboard.recentIncomingMessages.forEach((message) => { %>
                        <a href="/admin/conversations/<%= message.conversation.id %>" class="block px-6 py-4 hover:bg-slate-50">
                            <p class="font-semibold text-slate-900">
                                <%= message.conversation.contact.name || message.conversation.contact.profileName || message.conversation.contact.phone %>
                            </p>

                            <p class="mt-1 line-clamp-2 text-sm text-slate-600">
                                <%= message.body || "[" + message.type + "]" %>
                            </p>

                            <p class="mt-2 text-xs text-slate-400">
                                Agente:
                                <%= message.conversation.assignedUser ? message.conversation.assignedUser.name : "Sin asignar" %>
                            </p>
                        </a>
                    <% }) %>
                </div>
            </div>
        </section>

        <section class="mt-8 rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="font-bold text-slate-900">
                    Últimos errores o advertencias
                </h2>
            </div>

            <div class="divide-y divide-slate-100">
                <% if (dashboard.recentErrors.length === 0) { %>
                    <div class="px-6 py-8 text-sm text-slate-500">
                        No hay errores recientes.
                    </div>
                <% } %>

                <% dashboard.recentErrors.forEach((log) => { %>
                    <div class="px-6 py-4">
                        <div class="flex flex-wrap items-center gap-2">
                            <span class="rounded-full bg-red-50 px-3 py-1 text-xs font-semibold text-red-700">
                                <%= log.level %>
                            </span>

                            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                                <%= log.module %>
                            </span>

                            <span class="text-xs text-slate-400">
                                <%= log.createdAt.toLocaleString("es-MX") %>
                            </span>
                        </div>

                        <p class="mt-2 font-semibold text-slate-800">
                            <%= log.action %>
                        </p>

                        <p class="mt-1 text-sm text-slate-600">
                            <%= log.message %>
                        </p>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>
</div>

<%- include("../../partials/footer") %>
