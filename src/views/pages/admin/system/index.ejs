<%- include("../../../partials/header", { title: "Estado del sistema - Admin" }) %>

<div class="min-h-screen bg-slate-100">
    <%- include("../../../partials/admin-nav", { user }) %>

    <main class="mx-auto max-w-7xl px-4 py-8">
        <div class="mb-8">
            <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">
                Producción
            </p>

            <h1 class="mt-1 text-3xl font-black text-slate-900">
                Estado del sistema
            </h1>

            <p class="mt-2 text-slate-600">
                Revisa si Margarita está lista para operar con WhatsApp Cloud API.
            </p>
        </div>

        <section class="mb-8 grid gap-4 md:grid-cols-2 lg:grid-cols-5">
            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">WhatsApp</p>

                <p class="mt-2 text-lg font-black <%= status.checks.whatsappConfigured ? 'text-emerald-700' : 'text-red-700' %>">
                    <%= status.checks.whatsappConfigured ? "Configurado" : "Pendiente" %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Plantillas aprobadas</p>

                <p class="mt-2 text-3xl font-black text-slate-900">
                    <%= status.approvedTemplates %>
                </p>

                <p class="mt-1 text-xs text-slate-400">
                    Total: <%= status.totalTemplates %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Contactos activos</p>

                <p class="mt-2 text-3xl font-black text-slate-900">
                    <%= status.totalContacts %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Agentes activos</p>

                <p class="mt-2 text-3xl font-black text-slate-900">
                    <%= status.activeAgents %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Workspace</p>

                <p class="mt-2 text-lg font-black <%= status.checks.workspaceReady ? 'text-emerald-700' : 'text-red-700' %>">
                    <%= status.workspace?.status || "Sin estado" %>
                </p>
            </div>
        </section>

        <section class="mb-8 rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <div class="flex flex-col justify-between gap-4 lg:flex-row lg:items-center">
                <div>
                    <h2 class="text-xl font-black text-slate-900">
                        Webhook de Meta
                    </h2>

                    <p class="mt-2 text-sm text-slate-500">
                        Usa esta URL en Meta Developers para recibir mensajes y estados.
                    </p>
                </div>

                <a href="<%= status.webhookUrl %>" target="_blank" class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800">
                    Probar URL
                </a>
            </div>

            <div class="mt-5 rounded-xl bg-slate-50 p-4">
                <p class="text-xs font-semibold uppercase tracking-wide text-slate-500">
                    Callback URL
                </p>

                <p class="mt-2 break-all font-mono text-sm text-slate-800">
                    <%= status.webhookUrl %>
                </p>
            </div>

            <% if (status.whatsappAccount) { %>
                <div class="mt-5 grid gap-4 md:grid-cols-3">
                    <div class="rounded-xl border border-slate-200 p-4">
                        <p class="text-xs text-slate-500">Phone Number ID</p>
                        <p class="mt-1 break-all text-sm font-semibold text-slate-800">
                            <%= status.whatsappAccount.phoneNumberId %>
                        </p>
                    </div>

                    <div class="rounded-xl border border-slate-200 p-4">
                        <p class="text-xs text-slate-500">WABA ID</p>
                        <p class="mt-1 break-all text-sm font-semibold text-slate-800">
                            <%= status.whatsappAccount.businessAccountId %>
                        </p>
                    </div>

                    <div class="rounded-xl border border-slate-200 p-4">
                        <p class="text-xs text-slate-500">API Version</p>
                        <p class="mt-1 text-sm font-semibold text-slate-800">
                            <%= status.whatsappAccount.apiVersion %>
                        </p>
                    </div>
                </div>
            <% } else { %>
                <div class="mt-5 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                    No hay cuenta de WhatsApp configurada. Revisa variables de entorno y ejecuta seed.
                </div>
            <% } %>
        </section>

        <section class="mb-8 grid gap-6 lg:grid-cols-2">
            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <h2 class="text-xl font-black text-slate-900">
                    Últimos logs Webhook
                </h2>

                <div class="mt-5 space-y-3">
                    <% if (status.recentWebhookLogs.length === 0) { %>
                        <p class="text-sm text-slate-500">
                            Todavía no hay logs de webhook.
                        </p>
                    <% } %>

                    <% status.recentWebhookLogs.forEach((log) => { %>
                        <div class="rounded-xl bg-slate-50 p-4">
                            <div class="flex justify-between gap-4">
                                <p class="text-sm font-bold text-slate-800">
                                    <%= log.action %>
                                </p>

                                <span class="text-xs font-semibold text-slate-400">
                                    <%= log.level %>
                                </span>
                            </div>

                            <p class="mt-1 text-sm text-slate-500">
                                <%= log.message %>
                            </p>

                            <p class="mt-2 text-xs text-slate-400">
                                <%= formatDateTimeMX(log.createdAt) %>
                            </p>
                        </div>
                    <% }) %>
                </div>
            </div>

            <div class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
                <h2 class="text-xl font-black text-slate-900">
                    Últimos logs Meta
                </h2>

                <div class="mt-5 space-y-3">
                    <% if (status.recentMetaLogs.length === 0) { %>
                        <p class="text-sm text-slate-500">
                            Todavía no hay logs de Meta.
                        </p>
                    <% } %>

                    <% status.recentMetaLogs.forEach((log) => { %>
                        <div class="rounded-xl bg-slate-50 p-4">
                            <div class="flex justify-between gap-4">
                                <p class="text-sm font-bold text-slate-800">
                                    <%= log.action %>
                                </p>

                                <span class="text-xs font-semibold text-slate-400">
                                    <%= log.level %>
                                </span>
                            </div>

                            <p class="mt-1 text-sm text-slate-500">
                                <%= log.message %>
                            </p>

                            <p class="mt-2 text-xs text-slate-400">
                                <%= formatDateTimeMX(log.createdAt) %>
                            </p>
                        </div>
                    <% }) %>
                </div>
            </div>
        </section>

        <section class="rounded-2xl bg-white p-6 shadow-sm ring-1 ring-slate-200">
            <h2 class="text-xl font-black text-slate-900">
                Errores recientes
            </h2>

            <div class="mt-5 space-y-3">
                <% if (status.recentErrors.length === 0) { %>
                    <div class="rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                        No hay errores recientes.
                    </div>
                <% } %>

                <% status.recentErrors.forEach((log) => { %>
                    <div class="rounded-xl bg-red-50 p-4">
                        <div class="flex justify-between gap-4">
                            <p class="text-sm font-bold text-red-800">
                                <%= log.action %>
                            </p>

                            <span class="text-xs font-semibold text-red-500">
                                <%= log.level %>
                            </span>
                        </div>

                        <p class="mt-1 text-sm text-red-700">
                            <%= log.message %>
                        </p>

                        <p class="mt-2 text-xs text-red-400">
                            <%= formatDateTimeMX(log.createdAt) %>
                        </p>
                    </div>
                <% }) %>
            </div>
        </section>
    </main>
</div>

<%- include("../../../partials/footer") %>