<%- include("../../../partials/header", { title: "Logs - Admin" }) %>

<div class="min-h-screen bg-slate-100">
    <%- include("../../../partials/admin-nav", { user }) %>

    <main class="mx-auto max-w-7xl px-4 py-8">
        <div class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-end">
            <div>
                <p class="text-sm font-semibold uppercase tracking-wide text-emerald-600">
                    Operación
                </p>

                <h1 class="mt-1 text-3xl font-bold text-slate-900">
                    Logs del sistema
                </h1>

                <p class="mt-2 text-slate-600">
                    Revisa errores, advertencias y eventos importantes de Margarita.
                </p>
            </div>

            <a href="/admin/dashboard" class="rounded-xl bg-slate-900 px-5 py-3 text-sm font-semibold text-white hover:bg-slate-800">
                Volver al dashboard
            </a>
        </div>

        <form method="GET" action="/admin/logs" class="mb-6 grid gap-4 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200 md:grid-cols-3">
            <div>
                <label class="mb-1 block text-sm font-semibold text-slate-700">
                    Nivel
                </label>

                <select name="level" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
                    <option value="">Todos</option>
                    <option value="INFO" <%= filters.level === "INFO" ? "selected" : "" %>>INFO</option>
                    <option value="WARN" <%= filters.level === "WARN" ? "selected" : "" %>>WARN</option>
                    <option value="ERROR" <%= filters.level === "ERROR" ? "selected" : "" %>>ERROR</option>
                </select>
            </div>

            <div>
                <label class="mb-1 block text-sm font-semibold text-slate-700">
                    Módulo
                </label>

                <select name="module" class="w-full rounded-xl border border-slate-300 px-4 py-3 text-sm outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100">
                    <option value="">Todos</option>
                    <option value="AUTH" <%= filters.module === "AUTH" ? "selected" : "" %>>AUTH</option>
                    <option value="META" <%= filters.module === "META" ? "selected" : "" %>>META</option>
                    <option value="WEBHOOK" <%= filters.module === "WEBHOOK" ? "selected" : "" %>>WEBHOOK</option>
                    <option value="TEMPLATE" <%= filters.module === "TEMPLATE" ? "selected" : "" %>>TEMPLATE</option>
                    <option value="CONVERSATION" <%= filters.module === "CONVERSATION" ? "selected" : "" %>>CONVERSATION</option>
                    <option value="MESSAGE" <%= filters.module === "MESSAGE" ? "selected" : "" %>>MESSAGE</option>
                    <option value="SYSTEM" <%= filters.module === "SYSTEM" ? "selected" : "" %>>SYSTEM</option>
                </select>
            </div>

            <div class="flex items-end gap-2">
                <button class="w-full rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700">
                    Filtrar
                </button>

                <a href="/admin/logs" class="rounded-xl bg-slate-100 px-5 py-3 text-sm font-semibold text-slate-700 hover:bg-slate-200">
                    Limpiar
                </a>
            </div>
        </form>

        <section class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="font-bold text-slate-900">
                    Últimos 100 logs
                </h2>
            </div>

            <% if (logs.length === 0) { %>
                <div class="px-6 py-10 text-sm text-slate-500">
                    No hay logs con esos filtros.
                </div>
            <% } else { %>
                <div class="divide-y divide-slate-100">
                    <% logs.forEach((log) => { %>
                        <details class="group px-6 py-4">
                            <summary class="cursor-pointer list-none">
                                <div class="flex flex-col gap-3 md:flex-row md:items-start md:justify-between">
                                    <div>
                                        <div class="flex flex-wrap items-center gap-2">
                                            <span class="rounded-full px-3 py-1 text-xs font-bold <%= log.level === 'ERROR' ? 'bg-red-50 text-red-700' : log.level === 'WARN' ? 'bg-yellow-50 text-yellow-700' : 'bg-emerald-50 text-emerald-700' %>">
                                                <%= log.level %>
                                            </span>

                                            <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                                                <%= log.module %>
                                            </span>

                                            <span class="text-xs text-slate-400">
                                                <%= log.createdAt.toLocaleString("es-MX") %>
                                            </span>
                                        </div>

                                        <p class="mt-2 font-semibold text-slate-900">
                                            <%= log.action %>
                                        </p>

                                        <p class="mt-1 text-sm text-slate-600">
                                            <%= log.message %>
                                        </p>
                                    </div>

                                    <span class="text-xs font-semibold text-slate-400 group-open:hidden">
                                        Ver detalle
                                    </span>

                                    <span class="hidden text-xs font-semibold text-slate-400 group-open:inline">
                                        Ocultar detalle
                                    </span>
                                </div>
                            </summary>

                            <div class="mt-4 rounded-xl bg-slate-950 p-4">
                                <pre class="max-h-96 overflow-auto whitespace-pre-wrap break-words text-xs text-slate-100"><%= JSON.stringify(log.payload, null, 2) %></pre>
                            </div>
                        </details>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>
</div>

<%- include("../../../partials/footer") %>