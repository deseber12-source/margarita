<%- include("../../../partials/header", { title: "Campaña - Admin" }) %>

<%
    const recipientSummary = campaign.recipients.reduce(
        (acc, recipient) => {
            acc[recipient.status] = (acc[recipient.status] || 0) + 1;
            return acc;
        },
        {}
    );

    const failedRecipients = recipientSummary.FAILED || 0;
%>

<div class="min-h-screen bg-slate-100">
    <%- include("../../../partials/admin-nav", { user }) %>

    <main class="mx-auto max-w-7xl px-4 py-8">
        <div class="mb-8 flex flex-col justify-between gap-4 md:flex-row md:items-start">
            <div>
                <a href="/admin/campaigns" class="text-sm font-semibold text-emerald-600 hover:text-emerald-700">
                    ← Volver a campañas
                </a>

                <h1 class="mt-3 text-3xl font-bold text-slate-900">
                    <%= campaign.name %>
                </h1>

                <p class="mt-2 text-slate-600">
                    Plantilla:
                    <strong><%= campaign.template.name %></strong>
                    · <%= campaign.template.language %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-4 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    Estado
                </p>

                <p class="mt-1 text-xl font-bold text-slate-900">
                    <%= campaign.status %>
                </p>
            </div>
        </div>

        <% if (success === "created") { %>
            <div class="mb-6 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                Campaña creada correctamente.
            </div>
        <% } %>

        <% if (success === "sent") { %>
            <div class="mb-6 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                Campaña enviada. Revisa el estado de cada destinatario.
            </div>
        <% } %>

        <% if (success === "retry_failed") { %>
            <div class="mb-6 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                Destinatarios fallidos reintentados correctamente.
            </div>
        <% } %>

        <% if (error === "send") { %>
            <div class="mb-6 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                No se pudo enviar la campaña. Revisa logs y destinatarios.
            </div>
        <% } %>

        <% if (error && error !== "send") { %>
            <div class="mb-6 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                Ocurrió un error en la campaña.
            </div>
        <% } %>

        <% if (error === "retry_failed") { %>
            <div class="mb-6 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                No se pudieron reintentar los destinatarios fallidos.
            </div>
        <% } %>

        <section class="mb-6 grid gap-4 md:grid-cols-4">
            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">
                    Total
                </p>

                <p class="mt-2 text-3xl font-bold text-slate-900">
                    <%= campaign.totalRecipients %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-emerald-200">
                <p class="text-sm text-emerald-700">
                    Válidos
                </p>

                <p class="mt-2 text-3xl font-bold text-emerald-700">
                    <%= campaign.validRecipients %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-red-200">
                <p class="text-sm text-red-700">
                    Inválidos
                </p>

                <p class="mt-2 text-3xl font-bold text-red-700">
                    <%= campaign.invalidRecipients %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-orange-200">
                <p class="text-sm text-orange-700">
                    Duplicados
                </p>

                <p class="mt-2 text-3xl font-bold text-orange-700">
                    <%= campaign.duplicateRecipients %>
                </p>
            </div>
        </section>

        <section class="mb-6 grid gap-4 md:grid-cols-5">
            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
                <p class="text-sm text-slate-500">Pendientes</p>
                <p class="mt-2 text-3xl font-bold text-slate-700">
                    <%= recipientSummary.PENDING || 0 %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-blue-200">
                <p class="text-sm text-blue-700">Enviados</p>
                <p class="mt-2 text-3xl font-bold text-blue-700">
                    <%= recipientSummary.SENT || 0 %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-emerald-200">
                <p class="text-sm text-emerald-700">Entregados</p>
                <p class="mt-2 text-3xl font-bold text-emerald-700">
                    <%= recipientSummary.DELIVERED || 0 %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-purple-200">
                <p class="text-sm text-purple-700">Leídos</p>
                <p class="mt-2 text-3xl font-bold text-purple-700">
                    <%= recipientSummary.READ || 0 %>
                </p>
            </div>

            <div class="rounded-2xl bg-white p-5 shadow-sm ring-1 ring-red-200">
                <p class="text-sm text-red-700">Fallidos</p>
                <p class="mt-2 text-3xl font-bold text-red-700">
                    <%= recipientSummary.FAILED || 0 %>
                </p>
            </div>
        </section>


        <section class="mb-6 rounded-2xl bg-white p-5 shadow-sm ring-1 ring-slate-200">
            <div class="flex flex-col justify-between gap-4 md:flex-row md:items-center">
                <div>
                    <h2 class="font-bold text-slate-900">
                        Envío controlado
                    </h2>

                    <p class="mt-1 text-sm text-slate-500">
                        Envía destinatarios pendientes o reintenta solo los fallidos.
                    </p>
                </div>

                <div class="flex flex-wrap gap-3">
                    <% if (campaign.status === "DRAFT" || campaign.status === "READY" || campaign.status === "FAILED") { %>
                        <form action="/admin/campaigns/<%= campaign.id %>/send" method="POST">
                            <button class="rounded-xl bg-emerald-600 px-5 py-3 text-sm font-semibold text-white hover:bg-emerald-700">
                                Enviar campaña
                            </button>
                        </form>
                    <% } %>

                    <% if (failedRecipients > 0) { %>
                        <form action="/admin/campaigns/<%= campaign.id %>/retry-failed" method="POST">
                            <button class="rounded-xl bg-orange-500 px-5 py-3 text-sm font-semibold text-white hover:bg-orange-600">
                                Reintentar fallidos (<%= failedRecipients %>)
                            </button>
                        </form>
                    <% } %>

                    <% if (
                        campaign.status !== "DRAFT" &&
                        campaign.status !== "READY" &&
                        campaign.status !== "FAILED" &&
                        failedRecipients === 0
                    ) { %>
                        <span class="rounded-xl bg-slate-100 px-5 py-3 text-sm font-semibold text-slate-500">
                            No hay acciones disponibles en estado <%= campaign.status %>
                        </span>
                    <% } %>
                </div>
            </div>
        </section>

        <section class="overflow-hidden rounded-2xl bg-white shadow-sm ring-1 ring-slate-200">
            <div class="border-b border-slate-200 px-6 py-4">
                <h2 class="font-bold text-slate-900">
                    Destinatarios
                </h2>
            </div>

            <% if (campaign.recipients.length === 0) { %>
                <div class="px-6 py-10 text-sm text-slate-500">
                    No hay destinatarios.
                </div>
            <% } else { %>
                <div class="divide-y divide-slate-100">
                    <% campaign.recipients.forEach((recipient) => { %>
                        <div class="flex flex-col justify-between gap-3 px-6 py-4 md:flex-row md:items-center">
                            <div>
                                <p class="font-semibold text-slate-900">
                                    <% if (recipient.contact) { %>
                                        <%= recipient.contact.customName || recipient.contact.profileName || recipient.contact.phone %>
                                    <% } else { %>
                                        <%= recipient.phone %>
                                    <% } %>
                                </p>

                                <p class="text-sm text-slate-500">
                                    <%= recipient.phone %>
                                </p>

                                <% if (recipient.errorMessage) { %>
                                    <p class="mt-1 text-xs text-red-600">
                                        <%= recipient.errorMessage %>
                                    </p>
                                <% } %>
                            </div>

                            <div class="flex flex-wrap items-center gap-2">
                                <span class="rounded-full bg-slate-100 px-3 py-1 text-xs font-semibold text-slate-600">
                                    <%= recipient.status %>
                                </span>

                                <% if (recipient.message) { %>
                                    <span class="rounded-full bg-emerald-50 px-3 py-1 text-xs font-semibold text-emerald-700">
                                        Mensaje creado
                                    </span>
                                <% } %>
                            </div>
                        </div>
                    <% }) %>
                </div>
            <% } %>
        </section>
    </main>
</div>

<%- include("../../../partials/footer") %>