<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Etiquetas | Margarita</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="min-h-screen bg-slate-100">
    <header class="border-b bg-white">
        <div class="mx-auto flex max-w-6xl items-center justify-between px-6 py-4">
            <div>
                <h1 class="text-xl font-bold text-emerald-600">Margarita</h1>
                <p class="text-sm text-slate-500">Etiquetas</p>
            </div>

            <nav class="flex items-center gap-3">
                <a href="/admin/dashboard" class="text-sm font-medium text-slate-700">
                    Dashboard
                </a>

                <a href="/admin/users" class="text-sm font-medium text-slate-700">
                    Agentes
                </a>

                <a href="/admin/contacts" class="text-sm font-medium text-slate-700">
                    Contactos
                </a>

                <a href="/admin/tags" class="text-sm font-medium text-emerald-700">
                    Etiquetas
                </a>
                <a href="/admin/whatsapp" class="text-sm font-medium text-slate-700">
                    WhatsApp
                </a>
                <a href="/admin/templates" class="text-sm font-medium text-slate-700">
                    Plantillas
                </a>

                <a href="/admin/conversations" class="text-sm font-medium text-slate-700">
                    Conversaciones
                </a>

                <form action="/auth/logout" method="POST">
                    <button class="rounded-xl bg-slate-900 px-4 py-2 text-sm font-medium text-white">
                        Cerrar sesión
                    </button>
                </form>
            </nav>
        </div>
    </header>

    <main class="mx-auto max-w-6xl px-6 py-8">
        <section class="mb-6 flex items-center justify-between gap-4">
            <div>
                <h2 class="text-2xl font-bold text-slate-800">Etiquetas</h2>
                <p class="mt-1 text-slate-500">
                    Organiza contactos para operación y campañas.
                </p>
            </div>

            <a
                href="/admin/tags/new"
                class="rounded-xl bg-emerald-600 px-4 py-3 text-sm font-semibold text-white hover:bg-emerald-700"
            >
                Nueva etiqueta
            </a>
        </section>

        <% if (success) { %>
            <div class="mb-5 rounded-xl bg-emerald-50 px-4 py-3 text-sm text-emerald-700">
                Acción realizada correctamente.
            </div>
        <% } %>

        <section class="overflow-hidden rounded-2xl bg-white shadow">
            <table class="w-full text-left text-sm">
                <thead class="bg-slate-50 text-slate-500">
                    <tr>
                        <th class="px-5 py-4">Etiqueta</th>
                        <th class="px-5 py-4">Color</th>
                        <th class="px-5 py-4">Creada</th>
                        <th class="px-5 py-4 text-right">Acciones</th>
                    </tr>
                </thead>

                <tbody class="divide-y divide-slate-100">
                    <% if (tags.length === 0) { %>
                        <tr>
                            <td colspan="4" class="px-5 py-8 text-center text-slate-500">
                                Todavía no hay etiquetas creadas.
                            </td>
                        </tr>
                    <% } %>

                    <% tags.forEach((tag) => { %>
                        <tr>
                            <td class="px-5 py-4">
                                <span
                                    class="inline-flex items-center rounded-full px-3 py-1 text-xs font-semibold text-white"
                                    style="background-color: <%= tag.color || '#10b981' %>;"
                                >
                                    <%= tag.name %>
                                </span>
                            </td>

                            <td class="px-5 py-4 text-slate-600">
                                <%= tag.color || "—" %>
                            </td>

                            <td class="px-5 py-4 text-slate-600">
                                <%= tag.createdAt.toLocaleString("es-MX") %>
                            </td>

                            <td class="px-5 py-4">
                                <div class="flex justify-end gap-2">
                                    <a
                                        href="/admin/tags/<%= tag.id %>/edit"
                                        class="rounded-lg bg-slate-100 px-3 py-2 text-xs font-medium text-slate-700 hover:bg-slate-200"
                                    >
                                        Editar
                                    </a>

                                    <form
                                        action="/admin/tags/<%= tag.id %>/deactivate"
                                        method="POST"
                                        onsubmit="return confirm('¿Desactivar esta etiqueta?');"
                                    >
                                        <button class="rounded-lg bg-slate-900 px-3 py-2 text-xs font-medium text-white">
                                            Desactivar
                                        </button>
                                    </form>
                                </div>
                            </td>
                        </tr>
                    <% }) %>
                </tbody>
            </table>
        </section>
    </main>
</body>
</html>
