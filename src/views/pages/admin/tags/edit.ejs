<!DOCTYPE html>
<html lang="es">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Editar etiqueta | Margarita</title>
    <link rel="stylesheet" href="/css/style.css" />
</head>

<body class="min-h-screen bg-slate-100">
    <main class="mx-auto max-w-2xl px-6 py-10">
        <section class="mb-6">
            <a href="/admin/tags" class="text-sm font-medium text-emerald-700">
                ← Volver a etiquetas
            </a>

            <h1 class="mt-4 text-2xl font-bold text-slate-800">
                Editar etiqueta
            </h1>

            <p class="mt-1 text-slate-500">
                <%= tag.name %>
            </p>
        </section>

        <section class="rounded-2xl bg-white p-6 shadow">
            <% if (error) { %>
                <div class="mb-5 rounded-xl bg-red-50 px-4 py-3 text-sm text-red-700">
                    <%= error %>
                </div>
            <% } %>

            <form action="/admin/tags/<%= tag.id %>" method="POST" class="space-y-5">
                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">
                        Nombre
                    </label>

                    <input
                        name="name"
                        value="<%= tag.name %>"
                        required
                        class="w-full rounded-xl border border-slate-300 px-4 py-3 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                    />
                </div>

                <div>
                    <label class="mb-1 block text-sm font-medium text-slate-700">
                        Color
                    </label>

                    <input
                        name="color"
                        type="color"
                        value="<%= tag.color || '#10b981' %>"
                        class="h-12 w-full rounded-xl border border-slate-300 px-2 py-1 outline-none focus:border-emerald-500 focus:ring-2 focus:ring-emerald-100"
                    />
                </div>

                <button
                    type="submit"
                    class="w-full rounded-xl bg-emerald-600 px-4 py-3 font-semibold text-white hover:bg-emerald-700"
                >
                    Guardar cambios
                </button>
            </form>
        </section>
    </main>
</body>
</html>
